# Copy this file to ".env" and fill in your values.
# These are also the variables to set in Vercel (Project → Settings → Environment Variables).

# MongoDB connection string (free MongoDB Atlas cluster recommended).
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/youmatter?retryWrites=true&w=majority
MONGO_URI=

# Secret used to sign JWTs — any long random string.
JWT_SECRET=change_me_to_a_long_random_string

# How long a login stays valid.
JWT_EXPIRES_IN=7d

# Local API port (development only).
PORT=5000

# Frontend → API base URL. Leave as /api for local dev (Vite proxy) and Vercel.
# VITE_API_URL=/api
