{
  "name": "youmatter",
  "version": "1.0.0",
  "description": "YouMatter — React + Express + MongoDB (full-stack), deployable on Vercel.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm:server\" \"npm:client\"",
